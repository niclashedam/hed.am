---
layout: layouts/base.njk
pagination:
  data: collections.categories
  size: 1
  alias: category
permalink: "/blog/categories/{{ category.slug }}/"
eleventyComputed:
  title: "{{ category.name }} — Intelligence Briefs"
  description: "Intelligence Briefs in the {{ category.name }} category."
---
{% include 'components/header.njk' %}

<main id="main-content" class="bg-parchment">
  <section class="py-10 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <nav class="mb-8 text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="text-gold-600 hover:underline">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/blog" class="text-gold-600 hover:underline">Intelligence Briefs</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/blog/categories/" class="text-gold-600 hover:underline">Categories</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-gray-700">{{ category.name }}</li>
        </ol>
      </nav>

      <div class="flex items-center gap-4 mb-6">
        <a href="/blog/categories/" class="section-meta text-gold-600 hover:text-gold-500 transition-colors"
          >CATEGORIES</a
        >
        <span class="h-px flex-1 bg-parchment-dark max-w-[8rem]"></span>
      </div>
      <div class="mb-8">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">{{ category.name }}</h1>
        <p class="mt-3 text-sm text-gray-500 font-mono">
          {{ category.posts | length }}
          {%- if category.posts | length == 1 %} intelligence brief{%- else %} intelligence briefs{%- endif %}
        </p>
      </div>

      <div class="border-t border-parchment-dark pt-8 grid grid-cols-1 gap-x-8 gap-y-8 lg:grid-cols-3">
        {% for post in category.posts %}
          <article class="relative group overflow-hidden rounded-lg border border-parchment-dark bg-white hover:shadow-md transition-shadow">
            <img
              width="400"
              alt="{{ post.data.title }}"
              src="{{ post.data.image | url }}"
              class="h-48 w-full object-cover">
            <div class="p-5">
              <h2 class="text-base font-semibold text-gray-900 leading-snug group-hover:text-gold-700 transition-colors">
                <a href="{{ post.url }}" class="after:absolute after:inset-0 after:content-['']">
                  {{- post.data.title -}}
                </a>
              </h2>
              <p class="mt-1.5 text-xs text-gray-400 font-mono">
                <time datetime="{{ post.date | machineDate }}">{{ post.date | readableDate }}</time>
                &middot; {{ post.data.readingTime }} min read
              </p>
              <div class="mt-2 line-clamp-3 text-sm text-gray-600 leading-relaxed">{{ post.data.excerpt | safe }}</div>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
</main>
