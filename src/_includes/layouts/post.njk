---
layout: layouts/base.njk
type: article
author: Niclas Hedam
authorPic: /assets/images/niclas.jpeg
authorTitle: PhD, Computer Science
authorDescription: "Niclas Hedam holds a PhD in Computer Science from the IT University of Copenhagen. He is passionate about educating others on the importance of safeguarding personal information online."
---
{% include 'components/header.njk' %}

<main id="main-content" class="bg-parchment pt-8 pb-16 lg:pt-16 px-6 lg:px-8">
  <div class="mx-auto w-full max-w-2xl">
    <nav class="mb-4 text-sm text-gray-500 hidden md:block" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="text-gold-600 hover:underline">Home</a></li>
        <li class="text-gray-400">/</li>
        <li>
          <a href="/blog/" class="text-gold-600 hover:underline">Intelligence Briefs</a>
        </li>
        {% if category %}
          <li class="text-gray-400">/</li>
          <li>
            <a href="/blog/categories/{{ category | slugify }}/" class="text-gold-600 hover:underline">
              {{- canonicalCategory -}}
            </a>
          </li>
        {% endif %}
      </ol>
    </nav>
    <article
      class="mx-auto w-full max-w-2xl prose prose-sm sm:prose-base lg:prose-lg">
      <header class="mb-4 lg:mb-6 not-prose">
        <figure>
          <img
            width="672"
            src="{{ image | url }}"
            alt="{{ imageAlt }}"
            class="rounded-lg">
        </figure>
        <h1
          class="mb-6 text-4xl font-extrabold leading-tight text-gray-900 lg:mb-8 lg:text-5xl">
          {{ title }}
        </h1>
        <address class="flex items-center my-6 not-italic">
          <div class="h-16 w-16 flex-none overflow-hidden rounded-full mr-4">
            <img
              width="64"
              height="64"
              class="block h-full w-full object-cover"
              src="{{ authorPic | url }}"
              alt="{{ author }}">
          </div>
          <div class="text-gray-900">
            <a href="/" rel="author" class="text-lg font-bold">{{ author }}</a>
            <p class="text-base text-gray-500">{{ authorTitle }}</p>
            <p class="text-base text-gray-500">
              <time
                datetime="{{ date | machineDate }}"
                title="{{ date | machineDate }}">
                {{- date | readableDate -}}
              </time>
              · {{ readingTime }} min read
              {% if updates %}
                {% set lastUpdate = updates | last %}
                ·
                <a href="#updates" class="text-gold-600 hover:underline"
                  >Updated {{ lastUpdate.date | readableDate -}}
                </a>
              {% endif %}
            </p>
          </div>
        </address>
      </header>
      {% if tldr %}
        <div class="not-prose border border-parchment-dark bg-parchment-dark/45 rounded p-5 mb-6">
          <p class="section-meta text-steel-500 mb-4">TL;DR</p>
          <ul class="list-disc pl-5 space-y-2">
            {% for paragraph in tldr %}
              <li class="text-sm text-gray-700 leading-7 marker:text-gold-500 hyphens-auto text-justify">
                {{ paragraph }}
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
      <div class="prose hyphens-auto text-justify">{{ content | safe }}</div>
      {% if updates %}
        <div class="not-prose border border-gold-400 bg-gold-300/10 rounded p-5 mb-6" id="updates">
          <p class="section-meta text-gold-600 mb-4">UPDATE</p>
          <ul class="space-y-3">
            {% for update in updates %}
              <li class="flex items-baseline gap-3">
                <time
                  class="font-mono text-xs font-bold text-gold-600 shrink-0"
                  datetime="{{ update.date | machineDate }}">
                  {{- update.date | readableDate -}}
                </time>
                <span class="text-sm text-gray-700 leading-7 hyphens-auto text-justify">{{ update.note }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
      {% if opinion %}
        <div class="not-prose border border-steel-300 bg-steel-300/10 rounded p-5 mb-6">
          <p class="section-meta text-steel-500 mb-2">OPINION</p>
          <p class="text-sm text-gray-600 leading-7 hyphens-auto text-justify">
            The views expressed in this article are the author's own and do not represent the positions of any employer,
            institution, or organisation the author is affiliated with. All information provided in this article is
            based solely on public knowledge.
          </p>
        </div>
      {% endif %}
      <div>
        <address class="my-8 not-italic not-prose">
          <div class="border border-parchment-dark bg-parchment-dark/45 rounded p-6 font-mono">
            <p class="section-meta text-steel-500 mb-4">FILED BY</p>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <p class="text-base font-bold text-gray-900">{{ author }}</p>
                <p class="text-xs text-gold-600 tracking-widest uppercase font-bold mt-0.5">{{ authorTitle }}</p>
                <p class="text-sm text-gray-500 mt-2 max-w-sm font-sans hyphens-auto text-justify">
                  {{ authorDescription }}
                </p>
              </div>
              <div class="flex gap-4">
                {% for item in links %}
                  <a
                    href="{{ item.href }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="icon text-steel-400 hover:text-gold-500 text-xl transition-colors">
                    <span class="sr-only">{{ item.sr }}, opens in new tab</span>
                    <i class="{{ item.icon }}"></i>
                  </a>
                {% endfor %}
              </div>
            </div>
          </div>
        </address>
      </div>
    </article>
    <div class="mt-12 pt-8 border-t border-parchment-dark">
      <p class="section-meta text-steel-500 mb-6">RELATED BRIEFS</p>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        {% for post in relatedPosts %}
          <article class="relative group overflow-hidden rounded-lg border border-parchment-dark bg-white hover:shadow-md transition-shadow">
            <img
              width="320"
              alt="{{ post.data.title }}"
              src="{{ post.data.image | url }}"
              class="h-36 w-full object-cover">
            <div class="p-4">
              {% if post.data.category %}
                <a
                  href="/blog/categories/{{ post.data.category | slugify }}/"
                  class="relative z-10 section-meta text-gold-600 hover:text-gold-500 transition-colors">
                  {{ post.data.canonicalCategory }}
                </a>
              {% endif %}
              <h3 class="mt-1.5 text-sm font-semibold text-gray-900 leading-snug group-hover:text-gold-700 transition-colors">
                <a href="{{ post.url }}" class="after:absolute after:inset-0 after:content-['']">
                  {{- post.data.title -}}
                </a>
              </h3>
              <p class="mt-1 text-xs text-gray-400 font-mono">
                <time datetime="{{ post.date | machineDate }}">{{ post.date | readableDate }}</time>
                &middot; {{ post.data.readingTime }} min read
              </p>
              <div class="mt-1.5 line-clamp-2 text-xs text-gray-600">{{ post.data.excerpt | safe }}</div>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
    <div class="mt-8">
      <a href="/blog/" class="text-gold-600 hover:underline">&larr; Back to Intelligence Briefs</a>
    </div>
  </div>
</main>
