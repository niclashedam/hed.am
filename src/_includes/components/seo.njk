<!-- prettier-ignore -->
{% set seoTitle = title %}
{% if page.url != '/' %}
  {% set seoTitle = title + ' | Niclas Hedam' %}
{% endif %}
{% set seoDescription = excerpt or description %}
<title>{{ seoTitle }}</title>
<meta name="description" content="{{ description }}">
{% if author %}
  <meta name="author" content="{{ author }}">
{% endif %}
{% if keywords %}
  {% if keywords | length %}
    {% if keywords.join %}
      <meta name="keywords" content="{{ keywords | join(', ') }}">
    {% else %}
      <meta name="keywords" content="{{ keywords }}">
    {% endif %}
  {% endif %}
{% endif %}
<link rel="canonical" href="https://hed.am{{ page.url }}">
<meta property="og:type" content="{{ type | default('website') }}">
<meta property="og:site_name" content="hed.am">
<meta property="og:locale" content="en_US">
<meta property="og:title" content="{{ seoTitle }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="https://hed.am{{ page.url }}">
{% if image %}
  <meta property="og:image" content="https://hed.am{{ image | url }}">
  <meta property="og:image:alt" content="{{ imageAlt or title }}">
{% endif %}
<meta name="twitter:card" content="{{ 'summary_large_image' if image else 'summary' }}">
<meta name="twitter:title" content="{{ seoTitle }}">
<meta name="twitter:description" content="{{ description }}">
{% if image %}
  <meta name="twitter:image" content="https://hed.am{{ image | url }}">
{% endif %}
