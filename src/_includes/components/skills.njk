<section class="bg-parchment py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-8">
      <span class="section-meta text-steel-500">CAPABILITIES</span>
      <span class="h-px flex-1 bg-parchment-dark max-w-[8rem]"></span>
    </div>

    <div class="mx-auto max-w-2xl lg:max-w-none">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl mb-4">Capability Overview</h2>
      <p class="text-lg leading-8 text-gray-600 mb-16 max-w-2xl">
        Documented operational competencies across technical and strategic domains.
      </p>

      <dl class="grid grid-cols-1 gap-y-10 lg:grid-cols-2 lg:gap-x-16">
        {% for skill in skills %}
          <div>
            <dt class="flex gap-6 text-base font-semibold text-gray-900 mb-2">
              <span
                class="font-mono text-2xl font-bold text-gold-600 opacity-70 w-8 flex-shrink-0 pt-0.5"
                aria-hidden="true">
                {%- if loop.index < 10 %}0{% endif -%}
                {{- loop.index -}}
              </span>
              {{ skill.title }}
            </dt>
            <dd class="text-base leading-7 text-gray-600 pl-14">{{ skill.text }}</dd>
          </div>
        {% endfor %}
      </dl>
    </div>
  </div>
</section>
