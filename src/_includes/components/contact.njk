          <div class="h-px bg-navy-700"></div>
          <div class="flex gap-4">
            <span class="text-steel-400 w-28 flex-shrink-0">ALGORITHM</span>
            <span class="text-gray-300">Ed25519</span>
          </div>
          <div class="flex gap-4">
            <span class="text-steel-400 w-28 flex-shrink-0">KEY ID</span>
            <span class="text-gray-300 tracking-widest">1C71 8BA1 A100 6103</span>
          </div>
          <div class="flex gap-4">
            <span class="text-steel-400 w-28 flex-shrink-0">FORMAT</span>
            <span class="text-gray-300">PGP/MIME · Inline PGP</span>
          </div>
        </div>
      </div>
    </div>
