<section class="bg-parchment py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-8">
      <span class="section-meta text-steel-500">PUBLICATIONS</span>
      <span class="h-px flex-1 bg-parchment-dark max-w-[8rem]"></span>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-10">
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Intelligence Briefs</h2>
        <p class="mt-2 text-sm text-gray-500 font-mono">
          Research notes, technical analyses and intelligence perspectives.
        </p>
      </div>
      <a href="/blog/" class="section-meta text-gold-600 hover:text-gold-500 transition-colors shrink-0 pb-0.5">
        ALL BRIEFS →
      </a>
    </div>

    <div class="grid grid-cols-1 gap-x-8 gap-y-8 lg:grid-cols-3">
      {% for post in collections.blog | limit(3) %}
        <article class="relative group overflow-hidden rounded-lg border border-parchment-dark bg-white hover:shadow-md transition-shadow">
          <img
            width="400"
            alt="{{ post.data.title }}"
            src="{{ post.data.image | url }}"
            class="h-48 w-full object-cover">
          <div class="p-5">
            {% if post.data.category %}
              <a
                href="/blog/categories/{{ post.data.category | slugify }}/"
                class="relative z-10 section-meta text-gold-600 hover:text-gold-500 transition-colors">
                {{ post.data.canonicalCategory }}
              </a>
            {% endif %}
            <h3 class="mt-2 text-base font-semibold text-gray-900 leading-snug group-hover:text-gold-700 transition-colors">
              <a href="{{ post.url }}" class="after:absolute after:inset-0 after:content-['']">{{ post.data.title }}</a>
            </h3>
            <p class="mt-1.5 text-xs text-gray-400 font-mono">
              <time datetime="{{ post.date | machineDate }}">{{ post.date | readableDate }}</time>
              &middot; {{ post.data.readingTime }} min read
            </p>
            <div class="mt-2 text-sm text-gray-600 leading-relaxed hyphens-auto">
              {{ post.data.description | safe }}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
