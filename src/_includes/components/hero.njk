<noscript>
  <style>
    .hero-field,
    #hero-desc,
    #hero-cta {
      opacity: 1 !important;
    }
    .hf-val {
      clip-path: none !important;
    }
  </style>
</noscript>
<section
  class="min-h-screen bg-navy-900 flex items-center relative overflow-hidden"
  id="home">
  <div class="absolute inset-0 hero-grid-bg" aria-hidden="true"></div>
  <div class="hero-scan-line" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-24 w-full">
    <div class="max-w-2xl relative">
      <!-- DECLASSIFIED stamp -->
      <div class="declassified-stamp hidden sm:block" aria-hidden="true">
        <div class="stamp-title">Declassified</div>
        <div class="stamp-sub">Journal 2026-01446</div>
      </div>

      <!-- File reference header -->
      <div class="flex items-center gap-4 mb-8">
        <span class="section-meta text-steel-400">PERSONNEL FILE</span>
        <span class="h-px flex-1 bg-navy-700 max-w-[10rem]"></span>
      </div>

      <!-- Animated fields -->
      <div class="space-y-5" id="hero-fields">
        <div class="hero-field" id="hf-row-0">
          <span class="section-meta text-steel-500 w-32 flex-shrink-0">SUBJECT</span>
          <h1
            class="font-mono text-white text-3xl sm:text-5xl font-bold tracking-tight hf-val m-0 p-0"
            id="hf-val-0">
            {{- name -}}
          </h1>
        </div>

        <div class="hero-field" id="hf-row-1">
          <span class="section-meta text-steel-500 w-32 flex-shrink-0">ROLE</span>
          <span
            class="font-mono text-gold-500 text-xl font-semibold hf-val"
            id="hf-val-1"
            >Security Architect</span
          >
        </div>

        <div class="hero-field" id="hf-row-2">
          <span class="section-meta text-steel-500 w-32 flex-shrink-0">AFFILIATION</span>
          <span
            class="font-mono text-steel-300 text-sm hf-val"
            id="hf-val-2"
            >National Police of Denmark</span
          >
        </div>

        <div class="hero-field" id="hf-row-3">
          <span class="section-meta text-steel-500 w-32 flex-shrink-0">EXPERTISE</span>
          <span
            class="font-mono text-steel-300 text-sm hf-val"
            id="hf-val-3"
            >Infrastructure · Security · Privacy</span
          >
        </div>

        <div class="hero-field" id="hf-row-4">
          <span class="section-meta text-steel-500 w-32 flex-shrink-0">STATUS</span>
          <span
            class="font-mono text-gold-500 text-sm font-semibold hf-val"
            id="hf-val-4"
            >Active</span
          >
        </div>
      </div>

      <p
        class="mt-10 text-gray-200 max-w-xl leading-relaxed text-sm sm:text-base opacity-0"
        id="hero-desc">
        Security Architect with a strong academic foundation and hands-on experience in cybersecurity, consulting, and
        teaching.
      </p>

      <div
        class="mt-8 flex flex-wrap gap-6 font-mono text-sm opacity-0"
        id="hero-cta">
        <a href="#about" class="text-gold-500 hover:text-gold-400 tracking-wider transition-colors"
          ><span aria-hidden="true">→</span> READ FILE</a
        >
        <a href="#contact" class="text-steel-400 hover:text-steel-300 tracking-wider transition-colors"
          ><span aria-hidden="true">→</span> CONTACT</a
        >
        <a href="/blog" class="text-steel-400 hover:text-steel-300 tracking-wider transition-colors"
          ><span aria-hidden="true">→</span> BRIEFS</a
        >
      </div>
    </div>
  </div>
</section>
