{
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@cspell/dict-da-dk": "^4.1.2",
    "@shopify/prettier-plugin-liquid": "^1.10.2",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "axe-core": "^4.11.4",
    "cspell": "^9.7.0",
    "html-minifier-terser": "^7.2.0",
    "html-validate": "^10.11.2",
    "jsdom": "^29.0.2",
    "jsonld": "^9.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "prettier": "^3.8.3",
    "striptags": "^3.2.0",
    "tailwindcss": "^4.2.4",
    "terser": "^5.46.2",
    "title-case": "^4.3.2"
  },
  "scripts": {
    "build": "yarn clean && eleventy",
    "check": "node ./scripts/check.js",
    "check:format": "prettier . --check",
    "check:spelling": "yarn build && cspell --config cspell.json --no-progress \"public/**/*.html\"",
    "check:a11y": "yarn build && node ./scripts/a11y.js",
    "check:jsonld": "yarn build && node ./scripts/jsonld.js",
    "check:html": "yarn build && html-validate \"public/**/*.html\"",
    "check:headings": "node ./scripts/headings.js",
    "check:typography": "node ./scripts/typography.js",
    "check:links": "yarn build && node ./scripts/links.js",
    "clean": "rm -rf ./public && git checkout public",
    "format": "prettier . --write",
    "serve": "eleventy --serve"
  },
  "packageManager": "yarn@4.13.0"
}
