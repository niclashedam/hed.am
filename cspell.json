{
  "version": "0.2",
  "language": "en-GB",
  "dictionaryDefinitions": [
    {
      "name": "da-dk",
      "path": "./node_modules/@cspell/dict-da-dk/da_DK.trie",
      "description": "Danish (da-DK) Dictionary."
    }
  ],
  "dictionaries": ["en-gb", "da-dk", "html", "css", "softwareTerms", "misc"],
  "useGitignore": false,
  "ignorePaths": [],
  "patterns": [
    {
      "name": "pre",
      "pattern": "/<pre\\b(?=[^>]*\\bclass\\s*=\\s*(?:\\\"[^\\\"]*\\blanguage-[^\\\"]*\\\"|'[^']*\\blanguage-[^']*'))[^>]*>[\\s\\S]*?<\\/pre>/gi"
    },
    {
      "name": "code",
      "pattern": "/<code\\b[^>]*>[\\s\\S]*?<\\/code>/gi"
    }
  ],
  "ignoreRegExpList": ["<[^>]*>", "pre", "code"],
